# Eight Sleep credentials
EIGHT_SLEEP_EMAIL=you@example.com
EIGHT_SLEEP_PASSWORD=yourpassword

# Optional: override the embedded Eight Sleep app client credentials
# These are extracted from the Eight Sleep mobile app by the community.
# Only set these if the defaults stop working.
# EIGHT_SLEEP_CLIENT_ID=0894c7f33bb94800a03f1f4df13a4f38
# EIGHT_SLEEP_CLIENT_SECRET=f0954a3ed5763ba4e44ec7191b7a2e7b

# Optional: your Alexa Skill ID (amzn1.ask.skill.xxxx)
# When set, the webhook will reject requests from other skills.
# ALEXA_SKILL_ID=amzn1.ask.skill.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
